{
  "data": {
    "rawHtml": "<!DOCTYPE html><html lang=\"en\"><head><meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\n  \n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>FlexiPL — On-Demand Pallet Storage for Transport Operators</title>\n  <meta name=\"description\" content=\"Australia's first on-demand pallet storage marketplace. Book verified warehouse space online. Activate next business day. No lock-in, no waiting.\">\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com/\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com/\" crossorigin=\"\">\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap\" rel=\"stylesheet\">\n  <link rel=\"icon\" href=\"https://flexipl.com.au/logo512.png\" type=\"image/png\">\n  <link rel=\"stylesheet\" href=\"https://flexipl-landing.vercel.app/styles.css\">\n</head>\n<body>\n\n  <!-- Scroll Progress Bar -->\n  <div class=\"scroll-progress\" id=\"scrollProgress\"></div>\n\n  <!-- ==================== HEADER ==================== -->\n  <header class=\"header\" id=\"header\">\n    <div class=\"container header__inner\">\n      <a href=\"https://flexipl-landing.vercel.app/#\" class=\"header__logo\">\n        <img src=\"https://flexipl.com.au/logo512.png\" alt=\"FlexiPL icon\" class=\"header__logo-icon\">\n        <span class=\"header__logo-text\">FlexiPL</span>\n      </a>\n      <nav class=\"header__nav\">\n        <a href=\"https://flexipl-landing.vercel.app/#problem\">Why FlexiPL</a>\n        <a href=\"https://flexipl-landing.vercel.app/#guide\">How It Works</a>\n        <a href=\"https://flexipl-landing.vercel.app/#plan\">Get Started</a>\n        <a href=\"https://flexipl-landing.vercel.app/#success\">Use Cases</a>\n      </nav>\n      <div class=\"header__cta\">\n        <a href=\"https://flexipl.com.au/#instant-quote\" class=\"btn btn--primary magnetic-btn\" target=\"_blank\">\n          <span>Get Instant Quote</span>\n        </a>\n      </div>\n      <button class=\"header__hamburger\" id=\"hamburger\" aria-label=\"Menu\">\n        <span></span>\n        <span></span>\n        <span></span>\n      </button>\n    </div>\n  </header>\n\n  <!-- Mobile Nav -->\n  <div class=\"mobile-nav\" id=\"mobileNav\">\n    <a href=\"https://flexipl-landing.vercel.app/#problem\">Why FlexiPL</a>\n    <a href=\"https://flexipl-landing.vercel.app/#guide\">How It Works</a>\n    <a href=\"https://flexipl-landing.vercel.app/#plan\">Get Started</a>\n    <a href=\"https://flexipl-landing.vercel.app/#success\">Use Cases</a>\n    <a href=\"https://flexipl.com.au/#instant-quote\" class=\"btn btn--primary btn--large\" target=\"_blank\">Get Instant Quote</a>\n  </div>\n\n  <!-- ==================== HERO ==================== -->\n  <section class=\"hero\" id=\"hero\">\n    <!-- Full-bleed warehouse background -->\n    <div class=\"hero__bg\">\n      <img src=\"https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=1920&amp;h=1080&amp;fit=crop&amp;q=80\" alt=\"Large warehouse with organized pallet racking systems\" class=\"hero__bg-img\" loading=\"eager\">\n      <div class=\"hero__bg-overlay\"></div>\n    </div>\n    <!-- Animated orbs -->\n    <div class=\"hero__orb hero__orb--1\"></div>\n    <div class=\"hero__orb hero__orb--2\"></div>\n\n    <div class=\"container\">\n      <div class=\"hero__layout\">\n        <div class=\"hero__content reveal revealed\">\n          <div class=\"hero__badge\">\n            <span class=\"hero__badge-pulse\"></span>\n            <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13 10V3L4 14h7v7l9-11h-7z\"></path></svg>\n            Australia's First On-Demand Pallet Marketplace\n          </div>\n          <h1 class=\"hero__title\">\n            <span class=\"hero__title-line\">Pallet Storage for</span>\n            <span class=\"hero__title-line\">Transport Operators.</span>\n            <span class=\"hero__title-line hero__title-accent\">No Lock-In.</span>\n            <span class=\"hero__title-line hero__title-accent\">No Waiting.</span>\n          </h1>\n          <p class=\"hero__sub\">Australia's first on-demand pallet storage marketplace for transport operators. Find and book pallet storage from our national network of accredited warehouses.</p>\n          <div class=\"hero__actions\">\n            <a href=\"https://flexipl.com.au/#instant-quote\" class=\"btn btn--primary btn--large btn--icon btn--glow magnetic-btn\" target=\"_blank\">\n              <span>Get Instant Quote</span>\n              <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\"></path></svg>\n            </a>\n          </div>\n        </div>\n        <div class=\"hero__right reveal reveal--delay-2\">\n          <div class=\"hero__card tilt-card\">\n            <div class=\"hero__card-title\">\n              <span class=\"hero__card-dot\"></span>\n              Why operators choose FlexiPL\n            </div>\n            <div class=\"hero__card-feature\">\n              <div class=\"hero__card-icon\">\n                <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13 10V3L4 14h7v7l9-11h-7z\"></path></svg>\n              </div>\n              <div>\n                <h4>Activate Tomorrow</h4>\n                <p>Book today, store tomorrow. No site visits needed.</p>\n              </div>\n            </div>\n            <div class=\"hero__card-feature\">\n              <div class=\"hero__card-icon\">\n                <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg>\n              </div>\n              <div>\n                <h4>Daily Billing</h4>\n                <p>Pay only for days used. Scale with 24hr notice.</p>\n              </div>\n            </div>\n            <div class=\"hero__card-feature\">\n              <div class=\"hero__card-icon\">\n                <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z\"></path></svg>\n              </div>\n              <div>\n                <h4>Real-Time Tracking</h4>\n                <p>Monitor every pallet through OneTracker — live.</p>\n              </div>\n            </div>\n          </div>\n          <div class=\"hero__float hero__float--1\">\n            <div class=\"hero__float-dot\"></div>\n            <span>Live Pricing Active</span>\n          </div>\n          <div class=\"hero__float hero__float--2\">\n            <div class=\"hero__float-dot\"></div>\n            <span>99.9% Uptime</span>\n          </div>\n        </div>\n      </div>\n      <!-- Stats bar at bottom of hero -->\n      <div class=\"hero__stats-bar reveal\">\n        <div class=\"hero__stat\">\n          <div class=\"hero__stat-value\" data-count=\"200\">0</div>\n          <div class=\"hero__stat-suffix\">k+ sqm</div>\n          <div class=\"hero__stat-label\">Warehouse Space</div>\n        </div>\n        <div class=\"hero__stat-divider\"></div>\n        <div class=\"hero__stat\">\n          <div class=\"hero__stat-value\" data-count=\"50000\">0</div>\n          <div class=\"hero__stat-suffix\">+</div>\n          <div class=\"hero__stat-label\">Pallet Capacity</div>\n        </div>\n        <div class=\"hero__stat-divider\"></div>\n        <div class=\"hero__stat\">\n          <div class=\"hero__stat-value\" data-count=\"5\">0</div>\n          <div class=\"hero__stat-suffix\"> Cities</div>\n          <div class=\"hero__stat-label\">National Network</div>\n        </div>\n        <div class=\"hero__stat-divider\"></div>\n        <div class=\"hero__stat\">\n          <div class=\"hero__stat-value\" data-count=\"99.9\">0</div>\n          <div class=\"hero__stat-suffix\">%</div>\n          <div class=\"hero__stat-label\">Uptime</div>\n        </div>\n      </div>\n    </div>\n    <!-- Curved section divider -->\n    <div class=\"section-curve\">\n      <svg viewBox=\"0 0 1440 100\" preserveAspectRatio=\"none\"><path d=\"M0,0 C480,100 960,100 1440,0 L1440,100 L0,100 Z\" fill=\"var(--gray-50)\"></path></svg>\n    </div>\n  </section>\n\n  <!-- ==================== PROBLEM ==================== -->\n  <section class=\"problem\" id=\"problem\">\n    <div class=\"container\">\n      <div class=\"problem__layout\">\n        <div class=\"problem__left reveal\">\n          <div class=\"section-label\">The Problem</div>\n          <h2>Still Scrambling for Storage When a New Client Lands?</h2>\n          <p class=\"problem__desc\">A new contract arrives. Volumes spike. Your client needs pallets staged in a city where you don't have a depot. By the time you're set up, your client is already looking elsewhere.</p>\n          <div class=\"problem__image-block\">\n            <img src=\"https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=600&amp;h=400&amp;fit=crop\" alt=\"Crowded warehouse with stacked pallets\" class=\"problem__image\" loading=\"lazy\">\n          </div>\n        </div>\n        <div class=\"problem__right\">\n          <div class=\"problem__card reveal reveal--delay-1\" data-tilt=\"\">\n            <div class=\"problem__card-number\">01</div>\n            <div class=\"problem__card-icon\">\n              <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg>\n            </div>\n            <h3>Can't Mobilise Fast Enough</h3>\n            <p>New client wins that stall because you can't mobilise storage fast enough.</p>\n          </div>\n          <div class=\"problem__card reveal reveal--delay-2\" data-tilt=\"\">\n            <div class=\"problem__card-number\">02</div>\n            <div class=\"problem__card-icon\">\n              <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636\"></path></svg>\n            </div>\n            <h3>Peak Season Gridlock</h3>\n            <p>Peak season hits and every 3PL in the market is full — or slow to respond.</p>\n          </div>\n          <div class=\"problem__card reveal reveal--delay-3\" data-tilt=\"\">\n            <div class=\"problem__card-number\">03</div>\n            <div class=\"problem__card-icon\">\n              <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4\"></path></svg>\n            </div>\n            <h3>Cross-Dock Overflow</h3>\n            <p>Cross-dock overflow piles up at your depot with nowhere to go.</p>\n          </div>\n          <div class=\"problem__card reveal reveal--delay-1\" data-tilt=\"\">\n            <div class=\"problem__card-number\">04</div>\n            <div class=\"problem__card-icon\">\n              <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\"></path></svg>\n            </div>\n            <h3>Locked Into Leases</h3>\n            <p>Long-term leases lock you into fixed costs for space you need for weeks.</p>\n          </div>\n          <div class=\"problem__card reveal reveal--delay-2\" data-tilt=\"\">\n            <div class=\"problem__card-number\">05</div>\n            <div class=\"problem__card-icon\">\n              <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\"></path></svg>\n            </div>\n            <h3>Hidden Fees</h3>\n            <p>Hidden fees surface after you've committed — receiving charges, minimums, penalties.</p>\n          </div>\n          <div class=\"problem__card reveal reveal--delay-3\" data-tilt=\"\">\n            <div class=\"problem__card-number\">06</div>\n            <div class=\"problem__card-icon\">\n              <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21\"></path></svg>\n            </div>\n            <h3>No Visibility</h3>\n            <p>No real-time visibility on what's stored where.</p>\n          </div>\n        </div>\n      </div>\n      <div class=\"problem__cta reveal\">\n        <div class=\"problem__cta-inner\">\n          <p class=\"problem__soundbite\">There's a simpler way to handle overflow.</p>\n          <a href=\"https://flexipl.com.au/#instant-quote\" class=\"btn btn--primary btn--large btn--icon btn--glow magnetic-btn\" target=\"_blank\">\n            <span>See Live Pricing</span>\n            <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\"></path></svg>\n          </a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- ==================== GUIDE ==================== -->\n  <section class=\"guide\" id=\"guide\">\n    <div class=\"container\">\n      <div class=\"guide__top reveal\">\n        <div class=\"guide__header\">\n          <div class=\"section-label\">The Solution</div>\n          <h2>Simple, Flexible Storage for Transport Operators</h2>\n          <p>FlexiPL is Australia's first on-demand pallet storage marketplace — fully digital, built specifically for operators who need storage that moves as fast as their business.</p>\n          <p class=\"guide__highlight\">Book verified warehouse space online. Activate next business day. Pay only for the days you use.</p>\n        </div>\n        <div class=\"guide__hero-image\">\n          <img src=\"https://images.unsplash.com/photo-1553413077-190dd305871c?w=560&amp;h=380&amp;fit=crop\" alt=\"Forklift moving pallets in organized warehouse\" class=\"guide__image\" loading=\"lazy\">\n        </div>\n      </div>\n\n      <div class=\"guide__features\">\n        <div class=\"guide__feature reveal reveal--delay-1 tilt-card\">\n          <div class=\"guide__feature-icon\">\n            <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13 10V3L4 14h7v7l9-11h-7z\"></path></svg>\n          </div>\n          <div>\n            <h3>Instant Activation</h3>\n            <p>Book today, store tomorrow. No calls, no site visits.</p>\n          </div>\n        </div>\n        <div class=\"guide__feature reveal reveal--delay-2 tilt-card\">\n          <div class=\"guide__feature-icon\">\n            <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\"></path></svg>\n          </div>\n          <div>\n            <h3>Transparent Pricing</h3>\n            <p>See per-pallet daily rates before you commit. No hidden fees.</p>\n          </div>\n        </div>\n        <div class=\"guide__feature reveal reveal--delay-3 tilt-card\">\n          <div class=\"guide__feature-icon\">\n            <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z\"></path></svg>\n          </div>\n          <div>\n            <h3>Daily Billing</h3>\n            <p>Pay for what you use. Scale with 24-hour notice. No lock-in.</p>\n          </div>\n        </div>\n        <div class=\"guide__feature reveal reveal--delay-1 tilt-card\">\n          <div class=\"guide__feature-icon\">\n            <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z\"></path></svg>\n          </div>\n          <div>\n            <h3>Real-Time Tracking</h3>\n            <p>Monitor every pallet through OneTracker — live visibility, not end-of-day emails.</p>\n          </div>\n        </div>\n        <div class=\"guide__feature guide__feature--wide reveal reveal--delay-2 tilt-card\">\n          <div class=\"guide__feature-icon\">\n            <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg>\n          </div>\n          <div>\n            <h3>National Reach</h3>\n            <p>5 cities, one platform — Melbourne, Sydney, Brisbane, Adelaide, Perth.</p>\n          </div>\n          <div class=\"guide__feature-cities\">\n            <span class=\"guide__city-tag\">Melbourne</span>\n            <span class=\"guide__city-tag\">Sydney</span>\n            <span class=\"guide__city-tag\">Brisbane</span>\n            <span class=\"guide__city-tag\">Adelaide</span>\n            <span class=\"guide__city-tag\">Perth</span>\n          </div>\n        </div>\n      </div>\n\n      <!-- Stats Bar -->\n      <div class=\"guide__stats reveal\">\n        <div class=\"guide__stat\">\n          <div class=\"guide__stat-value\" data-count=\"200\">0</div>\n          <div class=\"guide__stat-suffix\">k+</div>\n          <div class=\"guide__stat-label\">Sqm Warehouse Space</div>\n        </div>\n        <div class=\"guide__stat\">\n          <div class=\"guide__stat-value\" data-count=\"50000\">0</div>\n          <div class=\"guide__stat-suffix\">+</div>\n          <div class=\"guide__stat-label\">Pallet Capacity</div>\n        </div>\n        <div class=\"guide__stat\">\n          <div class=\"guide__stat-value\" data-count=\"5\">0</div>\n          <div class=\"guide__stat-suffix\"></div>\n          <div class=\"guide__stat-label\">Cities Nationwide</div>\n        </div>\n        <div class=\"guide__stat\">\n          <div class=\"guide__stat-value\" data-count=\"99.9\">0</div>\n          <div class=\"guide__stat-suffix\">%</div>\n          <div class=\"guide__stat-label\">Platform Uptime</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- ==================== PLAN ==================== -->\n  <section class=\"plan\" id=\"plan\">\n    <div class=\"plan__bg-image\">\n      <img src=\"https://images.unsplash.com/photo-1565891741441-64926e441838?w=1400&amp;h=600&amp;fit=crop\" alt=\"Warehouse pallet racking aisles\" loading=\"lazy\">\n    </div>\n    <div class=\"container\">\n      <div class=\"plan__header reveal\">\n        <div class=\"section-label\">Getting Started</div>\n        <h2>Get Started in 3 Simple Steps</h2>\n      </div>\n      <div class=\"plan__steps\">\n        <div class=\"plan__step reveal reveal--delay-1 tilt-card\">\n          <div class=\"plan__step-number\">\n            <span class=\"plan__step-num\">01</span>\n            <div class=\"plan__step-icon\">\n              <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z\"></path></svg>\n            </div>\n          </div>\n          <h3>Get an Instant Quote</h3>\n          <p>Visit flexipl.com.au, select your storage type, quantity, and location. See live pricing instantly — no forms, no callbacks.</p>\n        </div>\n        <div class=\"plan__step-connector\">\n          <svg width=\"60\" height=\"24\" viewBox=\"0 0 60 24\"><path d=\"M0 12h50m-8-8l8 8-8 8\" stroke=\"var(--green)\" stroke-width=\"2\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg>\n        </div>\n        <div class=\"plan__step reveal reveal--delay-2 tilt-card\">\n          <div class=\"plan__step-number\">\n            <span class=\"plan__step-num\">02</span>\n            <div class=\"plan__step-icon\">\n              <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4\"></path></svg>\n            </div>\n          </div>\n          <h3>Choose Additional Services</h3>\n          <p>Add pick &amp; pack, labelling, handling, or stock management as needed. Everything priced upfront on the platform.</p>\n        </div>\n        <div class=\"plan__step-connector\">\n          <svg width=\"60\" height=\"24\" viewBox=\"0 0 60 24\"><path d=\"M0 12h50m-8-8l8 8-8 8\" stroke=\"var(--green)\" stroke-width=\"2\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg>\n        </div>\n        <div class=\"plan__step reveal reveal--delay-3 tilt-card\">\n          <div class=\"plan__step-number\">\n            <span class=\"plan__step-num\">03</span>\n            <div class=\"plan__step-icon\">\n              <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg>\n            </div>\n          </div>\n          <h3>Book Instantly</h3>\n          <p>Confirm your booking online. Storage is activated next business day. Track everything through OneTracker from day one.</p>\n        </div>\n      </div>\n      <div class=\"plan__cta reveal\">\n        <a href=\"https://flexipl.com.au/#instant-quote\" class=\"btn btn--primary btn--large btn--icon btn--glow magnetic-btn\" target=\"_blank\">\n          <span>See Live Pricing</span>\n          <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\"></path></svg>\n        </a>\n      </div>\n    </div>\n  </section>\n\n  <!-- ==================== SUCCESS ==================== -->\n  <section class=\"success\" id=\"success\">\n    <div class=\"container\">\n      <div class=\"success__header reveal\">\n        <div class=\"section-label\">Use Cases</div>\n        <h2>Storage That Fits How You Actually Operate</h2>\n        <p>Whether it's a one-off overflow or ongoing staging across multiple cities, FlexiPL adapts to your operation.</p>\n      </div>\n      <div class=\"success__grid\">\n        <div class=\"success__card reveal reveal--delay-1 tilt-card\">\n          <div class=\"success__card-image\">\n            <img src=\"https://images.unsplash.com/photo-1587293852726-70cdb56c2866?w=400&amp;h=240&amp;fit=crop\" alt=\"Forklift loading pallets at warehouse dock\" loading=\"lazy\">\n          </div>\n          <div class=\"success__card-body\">\n            <div class=\"success__card-header\">\n              <div class=\"success__card-icon\">\n                <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4\"></path></svg>\n              </div>\n              <h3>Cross-Dock Overflow</h3>\n            </div>\n            <p>Clear it from your depot into dedicated storage — same city, next day.</p>\n          </div>\n        </div>\n        <div class=\"success__card reveal reveal--delay-2 tilt-card\">\n          <div class=\"success__card-image\">\n            <img src=\"https://images.unsplash.com/photo-1578575437130-527eed3abbec?w=400&amp;h=240&amp;fit=crop\" alt=\"Transport truck at loading dock\" loading=\"lazy\">\n          </div>\n          <div class=\"success__card-body\">\n            <div class=\"success__card-header\">\n              <div class=\"success__card-icon\">\n                <svg fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13 10V3L4 14h7v7l9-11h-7z\"></path></svg>\n              </div>\n              <h3>New Client Mobilisation</h3>\n            </div>\n            <p>Win the contract, activate storage within 24 hours. No 3